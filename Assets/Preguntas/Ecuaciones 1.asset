  m_Script: {fileID: 11500000, guid: dc2ab1c3b3fa13b4a928f5b78b0518a8, type: 3}
  m_Name: Ecuaciones 1
  m_EditorClassIdentifier: 
  pregunta: "\xBFQu\xE9 es una ecuaci\xF3n lineal en una variable?\n\nA) Una igualdad
    donde la variable aparece solo con exponente 1\nB) Una igualdad donde la variable
    aparece con exponente mayor que 1\nC) Una expresi\xF3n que no tiene signo igual\nD)
    Una comparaci\xF3n con los signos menor que o mayor que"
  alternativas:
  - A
  - B
  - C
  - D
  indiceRespuestaCorrecta: 0
  feedbackSolucion: "Una ecuaci\xF3n lineal es una igualdad donde la variable est\xE1
    en primer grado, por ejemplo: 2x + 3 = 7."
