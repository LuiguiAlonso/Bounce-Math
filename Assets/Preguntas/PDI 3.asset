  m_Script: {fileID: 11500000, guid: dc2ab1c3b3fa13b4a928f5b78b0518a8, type: 3}
  m_Name: PDI 3
  m_EditorClassIdentifier: 
  pregunta: "La propiedad multiplicativa de la igualdad permite\u2026\n\nA) Multiplicar
    o dividir solo un lado\nB) Multiplicar o dividir ambos lados por el mismo n\xFAmero
    distinto de cero\nC) Intercambiar los lados\nD) Restar un mismo n\xFAmero solo
    a un lado"
  alternativas:
  - A
  - B
  - C
  - D
  indiceRespuestaCorrecta: 1
  feedbackSolucion: "Para mantener la igualdad, toda operaci\xF3n debe hacerse en
    ambos lados. Si multiplicas o divides solo uno, la igualdad deja de ser cierta."
