  m_Script: {fileID: 11500000, guid: dc2ab1c3b3fa13b4a928f5b78b0518a8, type: 3}
  m_Name: Funciones 1
  m_EditorClassIdentifier: 
  pregunta: "\xBFQu\xE9 representa la pendiente en una funci\xF3n lineal?\n\nA) El
    punto donde la gr\xE1fica cruza el eje x\nB) El valor inicial de la funci\xF3n\nC)
    El cambio que ocurre en la variable dependiente cuando la variable independiente
    aumenta en 1\nD) El n\xFAmero total de soluciones"
  alternativas:
  - A
  - B
  - C
  - D
  indiceRespuestaCorrecta: 2
  feedbackSolucion: "La pendiente indica cu\xE1nto aumenta o disminuye la funci\xF3n
    cuando x aumenta en 1. Es la medida de la inclinaci\xF3n de la recta."
