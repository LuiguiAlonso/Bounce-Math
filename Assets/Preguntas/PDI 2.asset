  m_Script: {fileID: 11500000, guid: dc2ab1c3b3fa13b4a928f5b78b0518a8, type: 3}
  m_Name: PDI 2
  m_EditorClassIdentifier: 
  pregunta: "\xBFCu\xE1l de las siguientes expresiones representa correctamente la
    propiedad aditiva de la igualdad?\n\nA) Si a = b, entonces a \xB1 c = b \xB1
    c\nB) Si a = b, entonces ac = b\nC) Si a = b, entonces c = c\nD) Si a = b, entonces
    a\xF7c = b"
  alternativas:
  - A
  - B
  - C
  - D
  indiceRespuestaCorrecta: 0
  feedbackSolucion: "La propiedad aditiva solo funciona si se suma o se resta el
    mismo n\xFAmero en los dos lados. No basta con cambiar uno solo."
